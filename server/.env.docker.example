# server/.env.docker.example — Docker Compose overrides template
# Copy this file to server/.env.docker and fill in real values.
# NEVER commit server/.env.docker — only commit this example file.
#
# These values override server/.env when running inside Docker Compose.
# The key difference: MONGODB_URI uses the Docker service name "mongo",
# not "localhost", because Docker Compose puts all services on the same
# internal network and routes by service name.

MONGODB_URI=mongodb://<mongo_root_user>:<mongo_root_password>@mongo:27017/<dbname>?authSource=admin
NODE_ENV=production
CLIENT_URL=http://localhost:3000
