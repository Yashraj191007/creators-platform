	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Status code is 200",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response has message field",
									"pm.test(\"Response has message field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData.message).to.be.a('string');",
									"});",
									"",
									"// Test 3: Response time is acceptable",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/api/health",
							"host": ["{{baseURL}}"],
							"path": ["api", "health"]
						},
						"description": "Checks that the server is up and running. Returns a 200 OK with a message and timestamp."
					},
					"response": []
				}
			],
			"description": "Server health check endpoint to verify the API is reachable."
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate a unique email to avoid 'user already exists' errors",
									"const timestamp = Date.now();",
									"const randomEmail = `user${timestamp}@example.com`;",
									"",
									"// Set as a temporary variable",
									"pm.variables.set('uniqueEmail', randomEmail);",
									"",
									"console.log('Generated email:', randomEmail);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Status code is 201",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"// Test 2: Response has _id",
									"pm.test(\"Response has _id field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('_id');",
									"});",
									"",
									"// Test 3: Response has email field",
									"pm.test(\"Response has email field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('email');",
									"    pm.expect(jsonData.email).to.be.a('string');",
									"});",
									"",
									"// Test 4: Response has name field",
									"pm.test(\"Response has name field\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('name');",
									"});",
									"",
									"// Test 5: Response time is acceptable",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(1000);",
									"});",
									"",
									"// Save the generated email for later use",
									"const jsonData = pm.response.json();",
									"if (jsonData.email) {",
									"    pm.environment.set('registeredEmail', jsonData.email);",
									"    console.log('Registered email saved:', jsonData.email);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{uniqueEmail}}\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/api/users/register",
							"host": ["{{baseURL}}"],
							"path": ["api", "users", "register"]
						},
						"description": "Creates a new user account. A unique email is auto-generated by the Pre-request Script to prevent duplicate errors. Returns user data with 201 status."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Status code is 200",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response has success: true",
									"pm.test(\"Response has success flag\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success');",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"// Test 3: Response has a token",
									"pm.test(\"Response has token\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('token');",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"});",
									"",
									"// Test 4: Response has user object",
									"pm.test(\"Response has user object\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('user');",
									"    pm.expect(jsonData.user).to.have.property('email');",
									"});",
									"",
									"// Test 5: Response time is acceptable",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});",
									"",
									"// Auto-save the token to the environment",
									"const response = pm.response.json();",
									"if (response.token) {",
									"    pm.environment.set('authToken', response.token);",
									"    console.log('Token saved:', response.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/api/auth/login",
							"host": ["{{baseURL}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Authenticates a user and returns a JWT. The Tests script automatically saves the token to the {{authToken}} environment variable so all subsequent authenticated requests work without manual copy-paste."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints — register and login. Login auto-saves the JWT to the environment."
		},
		{
			"name": "Posts",
			"item": [
				{
					"name": "Get All Posts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Test 1: Status code is 200",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Test 2: Response is an array",
									"pm.test(\"Response is an array\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"// Test 3: Response time is acceptable",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});",
									"",
									"// Save the first post ID for update/delete requests",
									"const posts = pm.response.json();",
									"if (posts.length > 0) {",
									"    pm.environment.set('postId', posts[0]._id);",
									"    console.log('Post ID saved:', posts[0]._id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
